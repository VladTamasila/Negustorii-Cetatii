{
    "name": "negustorii/cetatii",
    "description": "Negustorii Cetatii - API REST + UI (Sprint #3)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "php tests/scenariu.php",
        "gherkin": "php tests/gherkin.php"
    }
}
